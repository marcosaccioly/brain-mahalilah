# ── Google Gemini (TTS + STT para interface de voz) ────────────────────────────
# Obtenha em: https://aistudio.google.com/apikey
GOOGLE_API_KEY=AIza...

# ── Anthropic ──────────────────────────────────────────────────────────────────
# Obtenha em: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# Modelo Claude a usar (padrão: claude-opus-4-6)
# Opções: claude-opus-4-6 | claude-sonnet-4-6 | claude-haiku-4-5-20251001
CLAUDE_MODEL=claude-opus-4-6

# ── Servidor ───────────────────────────────────────────────────────────────────
PORT=3000

# ── Telegram Bot ──────────────────────────────────────────────────────────────
# Crie o bot via @BotFather no Telegram e cole o token aqui
TELEGRAM_BOT_TOKEN=

# URL do servidor (usado pelo bot para chamar /chat)
# Em produção, troque pelo domínio real
SERVER_URL=http://localhost:3000
